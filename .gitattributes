# Normalize line endings
* text=auto

# Force LF for these file types (cross-platform consistency)
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.env text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
