SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
BACKEND_CORS_ORIGINS=your_frontend_url
TAVILY_API_KEY=your-tavily-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Redis — Upstash: rediss://default:<PASSWORD>@<HOST>:<PORT>
# Leave empty to disable semantic caching (app works fine without it)
REDIS_URL=your_uptrash_redis_url
# REDIS_SEMANTIC_CACHE_THRESHOLD=0.95
# REDIS_CACHE_TTL=3600
